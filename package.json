{
  "name": "pkg-claim",
  "version": "1.0.1",
  "type": "module",
  "description": "Reserve an npm package name by publishing a minimal stub",
  "bin": {
    "pkg-claim": "./bin/pkg-claim.js"
  },
  "files": ["bin/"],
  "scripts": {
    "build": "tsdown",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "latest",
    "tsdown": "latest",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=24"
  }
}
