{
  "name": "pkg-claim",
  "version": "2.0.0",
  "type": "module",
  "description": "Reserve an npm package name by publishing a minimal stub",
  "bin": {
    "pkg-claim": "./bin/pkg-claim.js"
  },
  "files": [
    "bin/"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "prepublishOnly": "bun run build",
    "check": "bun test && bun run typecheck && bun run build",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "bun run check && changeset publish"
  },
  "dependencies": {
    "@clack/prompts": "1.2.0"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@types/bun": "latest",
    "@types/node": "latest",
    "tsdown": "latest",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=24"
  }
}
